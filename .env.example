# Copy to .env for local dev. On Railway, set these as service Variables instead.

# Required — your bot token (Discord Dev Portal → your app → Bot → Reset Token)
DISCORD_TOKEN=

# Required — the TMCast stream URL (a direct MP3 stream). Use your station slug.
# e.g. https://cast.tmc.gg/listen/one/radio.mp3
TMCAST_STREAM_URL=

# Optional — enables /nowplaying. TMCast's now-playing API for the station.
# e.g. https://cast.tmc.gg/api/np/one
TMCAST_NOWPLAYING_URL=

# Optional — display name used in messages
STATION_NAME=Mavion Radio One

# Optional — a server (guild) ID. If set, slash commands appear INSTANTLY in that
# server. Leave blank to register globally (can take up to ~1 hour the first time).
GUILD_ID=

# Optional — a voice channel ID. If set, the bot joins it and starts the radio
# automatically on startup (and after every restart/redeploy). Great for 24/7.
AUTOPLAY_CHANNEL_ID=

# Optional — audio bitrate sent to Discord (default 96k). Lower it (e.g. 64k) to
# reduce outbound bandwidth/egress; raise only on boosted servers.
AUDIO_BITRATE=

# Optional — automod is ON by default (blocks links from non-staff, severe slurs,
# and new-account image spam). Set to "off" to disable it entirely.
AUTOMOD=

# Optional — extra blocked words (comma-separated), added to the built-in slur list.
BADWORDS=
